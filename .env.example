# ── Required ──────────────────────────────────────────────────────────────
# PostgreSQL connection string.  Local dev default shown; for Supabase
# production, copy the connection string from Dashboard → Settings → Database.
DATABASE_URL=postgresql://cbm:cbm@localhost:5432/cbm

# ── Optional — features degrade gracefully if unset ──────────────────────

# Anthropic API key for AI-powered extraction (script 04) and natural-
# language queries (/api/natural-query).  Sign up at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Shared secret for the review queue (flag/unflag endpoints).  Generate
# with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# If unset, review queue endpoints return 503.
REVIEW_API_KEY=

# "dev" enables /api/docs (Swagger UI) and human-readable log output.
# Any other value (or unset) uses structured JSON logging and disables docs.
ENVIRONMENT=production

# ── Connection pool tuning (optional) ────────────────────────────────────
# DB_POOL_MIN=1
# DB_POOL_MAX=10

# ── Supabase production URL (used by db/migrate.sh for remote deploys) ───
# Copy from Supabase Dashboard → Settings → Database → Connection string (URI).
# Keep in .env only — never commit to git.
# SUPABASE_URL=postgresql://postgres.xxxxx:password@aws-0-eu-west-1.pooler.supabase.com:6543/postgres
